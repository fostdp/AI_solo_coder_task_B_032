# ============================================
# 锂电池化成工艺监控系统 - 环境变量配置
# ============================================

# 时区设置
TZ=Asia/Shanghai

# 数据存储路径（宿主机）
DATA_PATH=./data

# ============================================
# MQTT Broker (EMQX) 配置
# ============================================
MQTT_BROKER=mqtt-broker
MQTT_PORT=1883
MQTT_SUB_TOPIC=battery/cabinet/+/data
MQTT_ALERT_TOPIC=battery/alerts
MQTT_CLIENT_ID=battery-monitor
MQTT_USERNAME=
MQTT_PASSWORD=

# EMQX Dashboard
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=public

# ============================================
# ClickHouse 配置
# ============================================
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=battery_monitor
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CH_BATCH_SIZE=1024
CH_FLUSH_INTERVAL=5000

# ============================================
# Rust 后端服务配置
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# 异常检测配置
ANOMALY_SIGMA_THRESHOLD=3.0
ANOMALY_ABSOLUTE_THRESHOLD=0.02
DEGRADED_CAPACITY_RATIO=0.9
CABINET_ANOMALY_RATIO=0.1
VOLTAGE_ABSOLUTE=0.05
TEMP_THRESHOLD=50.0

# 容量预测配置
PREDICTION_MIN_CYCLES=3
PREDICTION_CONFIDENCE_THRESHOLD=0.8

# 告警配置
ENABLE_MES=true
ENABLE_SCREEN=true
ALERT_DEDUP_WINDOW=300

# 模型配置
MODEL_CONFIG_PATH=/app/model_config.json
DEFAULT_MODEL=NMC_3Ah
NUM_CABINETS=20
CHANNELS_PER_CABINET=512

# Rust 日志配置
RUST_LOG=info,battery_monitor=info
RUST_BACKTRACE=1

# ============================================
# 化成柜模拟器配置
# ============================================
SIM_NUM_CABINETS=20
SIM_CHANNELS_PER_CABINET=512
SIM_REPORT_INTERVAL=10
SIM_ABNORMAL_RATIO=0.03
SIM_ANOMALY_DURATION_MIN=60
SIM_ANOMALY_DURATION_MAX=300
SIM_RATED_CAPACITY=3.2
SIM_CAPACITY_FACTOR_MIN=0.85
SIM_CAPACITY_FACTOR_MAX=1.05
SIM_BATCH_SIZE=64
SIM_MQTT_QOS=1
SIM_MQTT_TOPIC_TEMPLATE=battery/cabinet/{cabinet_id}/data

# ============================================
# Grafana 配置
# ============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ============================================
# Prometheus 配置
# ============================================
PROMETHEUS_RETENTION_DAYS=15
PROMETHEUS_RETENTION_SIZE=50GB
