# MQTT Configuration
MQTT_BROKER=mqtt-broker
MQTT_PORT=1883
MQTT_SUB_TOPIC=battery/cabinet/+/data
MQTT_ALERT_TOPIC=battery/alerts
MQTT_CLIENT_ID=battery-monitor
MQTT_USERNAME=
MQTT_PASSWORD=

# ClickHouse Configuration
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=battery_monitor
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CH_BATCH_SIZE=1024
CH_INTERVAL=1000

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Detection Configuration
VOLTAGE_SIGMA=3.0
VOLTAGE_ABSOLUTE=0.05
CAPACITY_WARNING=0.90
TEMP_THRESHOLD=50.0
CABINET_ABNORMAL_RATIO=0.10
PREDICTION_CYCLES=3
PREDICTION_MIN_CYCLES=3

# Alert Configuration
ENABLE_MES=true
ENABLE_SCREEN=true
ALERT_DEDUP=300

# Model Configuration
MODEL_CONFIG_PATH=/app/model_config.json
DEFAULT_MODEL=NMC_3Ah

# Rust Logging
RUST_LOG=info,battery_monitor=debug
RUST_BACKTRACE=1

# Simulator Configuration
NUM_CABINETS=20
CHANNELS_PER_CABINET=512
REPORT_INTERVAL=10
ABNORMAL_RATIO=0.03
ANOMALY_DURATION_MIN=60
ANOMALY_DURATION_MAX=300
RATED_CAPACITY=3.2
CAPACITY_FACTOR_MIN=0.85
CAPACITY_FACTOR_MAX=1.05
BATCH_SIZE=64
MQTT_QOS=1
MQTT_TOPIC_TEMPLATE=battery/cabinet/{cabinet_id}/data

# Timezone
TZ=Asia/Shanghai
