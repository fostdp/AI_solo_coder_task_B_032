# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_SUB_TOPIC=battery/cabinet/+/data
MQTT_ALERT_TOPIC=battery/alerts
MQTT_CLIENT_ID=battery-monitor

# ClickHouse Configuration
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=battery_monitor
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CH_BATCH_SIZE=1024
CH_INTERVAL=1000

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Detection Configuration
VOLTAGE_SIGMA=3.0
VOLTAGE_ABSOLUTE=0.05
CAPACITY_WARNING=0.90
TEMP_THRESHOLD=50.0
CABINET_ABNORMAL_RATIO=0.10
PREDICTION_CYCLES=3
PREDICTION_MIN_CYCLES=3

# Alert Configuration
ENABLE_MES=true
ENABLE_SCREEN=true
ALERT_DEDUP=300

# Rust Logging
RUST_LOG=info,battery_monitor=debug
